import std.frte

"balls\n" print

var test 1 <<-

test -> 0 = if
    'a' .@
else 
    test -> 1 = if 
        'b' .@
    done
done 


for var a 0 <<-
    cond a -> 5  <
    step a ++
    do
        a -> 0 = if
            'a' .@
        else 
            a -> 2 = if 
                'b' .@
            done
        done 
done

var b 10 <<-

while b -> 0 > do
    b -> .# \n
    b --
done

